REGISTRY_BIND=0.0.0.0:8080
REGISTRY_DB_URL=postgres://jwc:jwc@localhost:5432/jwc_registry
REGISTRY_STORAGE_PATH=./storage
REGISTRY_MAX_UPLOAD_BYTES=52428800

# https://console.cloud.google.com/apis/credentials → OAuth client (Web)
REGISTRY_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
REGISTRY_GOOGLE_CLIENT_SECRET=your-secret
REGISTRY_GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# HMAC-SHA256 secret for session JWTs. Generate with: openssl rand -hex 32
REGISTRY_JWT_SECRET=change-me-32-bytes-random
REGISTRY_JWT_TTL_SECS=604800
